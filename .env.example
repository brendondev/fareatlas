# Neon PostgreSQL (pooled for app runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/fareatlas?sslmode=require"

# Neon direct / unpooled (migrations & prisma db push)
# If Neon only provides DATABASE_URL_UNPOOLED, copy that value here.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/fareatlas?sslmode=require"

# Signs the session cookie. Must be at least 32 chars — session.ts throws if
# it is shorter, rather than silently signing with a weak key.
# Generate: openssl rand -base64 32
# Accounts are only enabled when this AND DATABASE_URL are set; without both,
# /login, /register and /account return 404 and everyone is an anonymous free
# viewer.
SESSION_SECRET=""

# Seats.aero Partner API
AWARD_AVAILABILITY_API_KEY=""
# SEATS_AERO_API_KEY=""

# Cash fares — stage 2 (Amadeus)
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""

# Canonical site URL for links in emails (alerts, password reset). Without it,
# links fall back to the per-deploy VERCEL_URL. Set to your real domain.
NEXT_PUBLIC_SITE_URL=""

# Email delivery (Resend). Award alerts and password reset send once BOTH are
# set and the sender domain is verified; until then they degrade honestly.
RESEND_API_KEY=""
EMAIL_FROM=""

# Protects /api/cron/* (award-cache AND award-alerts). Vercel Cron sends
# Authorization: Bearer <CRON_SECRET>. The alerts cron is meant to be hit by an
# external scheduler (cron-job.org / GitHub Actions) every ~15-30 min at:
#   /api/cron/award-alerts?secret=<CRON_SECRET>
CRON_SECRET=""
FORCE_SEED=""
