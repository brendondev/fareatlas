// FareAtlas — Neon PostgreSQL (Vercel Marketplace / Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model LoyaltyProgram {
  id          String   @id @default(cuid())
  slug        String   @unique // qantas | velocity | everyday | flybuys
  name        String
  shortCode   String
  description String
  color       String   @default("#c9a961")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  offers        Offer[]
  userPrograms  UserProgram[]
  wineDeals     WineDeal[]
  giftCardRates GiftCardRate[]
  cardOffers    CardOffer[]
}

/// A registered account. Identity used to live as a loose email string on
/// AwardWatch; this is now the real thing.
model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String?

  /// free | premium | pro. A String rather than an enum, matching Offer.status
  /// and AwardWatch.status. Narrowed in TS at the DAL boundary, where anything
  /// unrecognised fails closed to "free".
  ///
  /// The Stripe webhook is now the primary writer (a paid checkout flips this,
  /// a cancellation/failure flips it back to "free"). scripts/grant-tier.mjs
  /// still writes it by hand for comp accounts; tierNote records why.
  tier      String    @default("free")
  tierNote  String?
  tierSince DateTime?

  /// Stripe billing linkage. All nullable: a Free account that never checked
  /// out has none of these, and adding them to a populated table is a no-op
  /// (see db-setup.mjs, which runs `db push` without --accept-data-loss).
  ///
  /// `tier` above stays the source of truth the app reads for entitlements;
  /// these columns are the audit trail and the keys the webhook joins on.
  ///
  /// Deliberately NOT @unique on stripeCustomerId — same reasoning as
  /// AwardWatch.unsubToken: adding a unique constraint to a populated table
  /// trips `db push`'s data-loss gate, which db-setup.mjs will not override.
  /// Uniqueness is enforced in code instead (ensureCustomer mints one customer
  /// per account), and the webhook looks the column up with findFirst, so an
  /// index is all it needs.
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  stripePriceId          String?
  stripeStatus           String? // active | trialing | past_due | canceled | ...
  stripeCurrentPeriodEnd DateTime?

  /// Unused until the email phase. Shipped now so that adding it later doesn't
  /// mean altering a table that by then holds real accounts.
  emailVerified DateTime?

  /// Per-account lockout, complementing the IP/email rate limit.
  failedLogins Int       @default(0)
  lockedUntil  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  watches  AwardWatch[]
  programs UserProgram[]
  tokens   AuthToken[]

  @@index([tier])
  @@index([stripeCustomerId])
}

/// Programs a user follows — the "my programs" list on /account.
model UserProgram {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId String
  program   LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([userId, programId])
  @@index([userId])
}

/// Password reset and email verification tokens. Only the SHA-256 of the
/// emailed token is stored, so a database leak cannot be replayed.
model AuthToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  purpose   String // reset | verify
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, purpose])
  @@index([expiresAt])
}

/// Fixed-window rate limiter, in the database on purpose.
///
/// An in-memory Map is worse than nothing here: every serverless instance has
/// its own heap and they scale horizontally and cold-start freely, so a limit
/// of 5 silently becomes 5xN and resets on deploy. Auth requires DATABASE_URL
/// by construction (see lib/auth-config.ts), so the table is always available
/// on any path that needs limiting.
model RateLimit {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "login:ip:1.2.3.4" | "login:email:a@b.c"
  count       Int      @default(0)
  windowStart DateTime @default(now())

  @@index([windowStart])
}

/// Premium interest, captured on /pricing when billing is not configured
/// (isBillingConfigured() false) — the honest fallback for a deploy without
/// Stripe keys. When billing is live the pricing CTAs go to Checkout instead.
model PremiumWaitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  userId    String?
  reason    String?
  createdAt DateTime @default(now())
}

/// Webhook idempotency ledger. Stripe delivers each event at least once and
/// retries on any non-2xx, so the same event.id can arrive several times. The
/// handler inserts the id here first; a duplicate insert (unique PK) means
/// "already processed" and the handler returns 200 without re-applying it.
/// Guards against, e.g., a retried subscription.deleted re-downgrading an
/// account the user has since re-subscribed to.
model StripeEvent {
  id        String   @id // Stripe event id (evt_...)
  type      String
  createdAt DateTime @default(now())

  @@index([type])
}

model Offer {
  id          String         @id @default(cuid())
  programId   String
  program     LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  title       String
  summary     String
  category    String // groceries | travel | shopping | marketplace | cards | wine | other
  estimate    String?
  url         String?
  featured    Boolean        @default(false)
  status      String         @default("published") // draft | published | archived
  expiresAt   DateTime?
  publishedAt DateTime       @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, publishedAt])
  @@index([programId, status])
  @@index([category])
}

/// A watched route.
///
/// `email` stays, and `userId` is nullable, for two reasons: rows created
/// before accounts existed have no user to point at and must survive, and
/// anonymous watches are still allowed. On register/login we claim orphans by
/// matching email, so someone who watched a route before signing up keeps it.
///
/// Deliberately not `userId String @unique`: a user has many watches, and a
/// non-null unique column cannot be added to a populated table anyway.
model AwardWatch {
  id          String    @id @default(cuid())
  email       String
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  origin      String
  destination String
  cabins      String    @default("economy,business") // comma-separated
  programs    String? // optional seats.aero sources
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("active") // active | paused | unsubscribed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // --- alerting state (all nullable/additive → safe db push on live rows) ---

  /// When the alerts cron last searched this route. Gates eligibility: a watch
  /// checked under CHECK_THRESHOLD ago is skipped, so scheduler frequency is
  /// decoupled from Seats.aero call frequency.
  lastCheckedAt  DateTime?
  /// Cooldown for email — don't send more than one alert per watch per window.
  lastNotifiedAt DateTime?
  /// Sorted set of available "cabin|date|source" keys from the last check.
  /// New availability = current keys minus these.
  lastSeenJson   String?
  /// When availability was last found (surfaced in /account without email).
  lastHitAt      DateTime?
  /// Human summary of the last hit, e.g. "Business SYD→HND · 90k pts · 2 seats".
  lastHitSummary String?
  /// Opaque one-click unsubscribe token (192 random bits). Lives on the watch,
  /// not AuthToken, whose required userId FK doesn't fit anonymous watches.
  ///
  /// NOT @unique on purpose: adding a unique constraint to a populated table
  /// trips Prisma db push's data-loss gate, and `db-setup.mjs` runs without
  /// --accept-data-loss (which would blindly accept any future data loss).
  /// The randomness makes collisions a non-issue; lookups use findFirst.
  unsubToken     String?

  @@index([status, lastCheckedAt])
  @@index([unsubToken])
  @@index([email, status])
  @@index([userId, status])
  @@index([origin, destination])
}

/// Wine bonus-point deals (Qantas Wine, Virgin Wine). Editorial, curated.
///
/// Stores inputs only. The ranking metric — cost per 1,000 bonus points — is a
/// pure function of priceAud and bonusPoints (see lib/verticals.ts) and is NOT
/// a column: persisting a derived value means it silently goes stale the day
/// someone edits priceAud in the console, which is the programs-vs-seed drift
/// bug all over again. `bottles` is here so the UI can show $/bottle beside the
/// points cost — ranking a $200 case above a $60 one on points alone is
/// correct and useless.
model WineDeal {
  id          String         @id @default(cuid())
  programId   String
  program     LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  title       String
  vendor      String // "Qantas Wine" | "Virgin Wine"
  bonusPoints Int
  priceAud    Float
  bottles     Int?
  url         String?
  status      String         @default("published")
  expiresAt   DateTime?
  publishedAt DateTime       @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, publishedAt])
}

/// Gift-card earn rates. `pointsPerDollar` is an input here (the advertised
/// rate), not a derivative, so it is stored and indexed for ranking.
model GiftCardRate {
  id              String         @id @default(cuid())
  programId       String
  program         LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  retailer        String
  channel         String // "Qantas Marketplace" | "Velocity Store"
  pointsPerDollar Float
  minSpendAud     Float?
  capAud          Float?
  url             String?
  status          String         @default("published")
  expiresAt       DateTime?
  publishedAt     DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status, pointsPerDollar])
}

/// Credit-card sign-up bonuses. First-year fee sits next to the bonus so the UI
/// can derive cost per 1,000 bonus points (feeFirstYear / bonus × 1000) — the
/// same axis as wine, making cards and wine directly comparable.
model CardOffer {
  id              String          @id @default(cuid())
  programId       String?
  program         LoyaltyProgram? @relation(fields: [programId], references: [id])
  issuer          String
  cardName        String
  bonusPoints     Int
  minSpendAud     Float?
  spendWindowDays Int?
  annualFeeAud    Float?
  feeFirstYearAud Float?
  eligibility     String?
  url             String?
  status          String          @default("published")
  expiresAt       DateTime?
  publishedAt     DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status, bonusPoints])
}

/// Cached cash fare snapshots (Amadeus later; seed for demo).
model CashFare {
  id           String   @id @default(cuid())
  origin       String
  destination  String
  routeLabel   String
  airline      String
  travelWindow String
  priceAud     Float
  note         String?
  active       Boolean  @default(true)
  capturedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([origin, destination, active])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

/// Daily Seats.aero search cache (saves Partner API quota).
/// Rows for previous days are wiped by /api/cron/award-cache.
model AwardSearchCache {
  id           String   @id @default(cuid())
  /// Hash of dayKey + normalized search params (unique per day).
  queryKey     String   @unique
  dayKey       String
  origin       String
  destination  String
  startDate    String?
  endDate      String?
  paramsJson   String
  /// Full Seats.aero /search JSON response.
  responseJson String
  hitCount     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([dayKey])
  @@index([origin, destination, dayKey])
}

/// Daily Seats.aero trip-detail cache for Availability IDs.
model AwardTripCache {
  id              String   @id @default(cuid())
  queryKey        String   @unique
  dayKey          String
  availabilityId  String
  includeFiltered Boolean  @default(false)
  responseJson    String
  hitCount        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([dayKey])
  @@index([availabilityId, dayKey])
}
